# Secrets & local config (copy the .example files instead)
.env
axon.config.yaml
prices.yaml

# AXON runtime state (per-profile data dir, if placed inside the repo)
.axon/
*.sqlite
*.sqlite-*
profiles/

# Go build output
/axon
/axon.exe
/dist/
/bin/
*.test
*.out
coverage.*

# Dashboard SPA (web/) — Node toolchain at build time only.
# Ignore the Vite build output, but keep a committed placeholder so the Go
# `embed all:dist` compiles on a fresh clone (the dashboard serves a fallback
# page until `npm run build` produces the real SPA; install.sh does this).
web/node_modules/
web/dist/*
!web/dist/.gitkeep
web/.vite/
npm-debug.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
