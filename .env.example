# =============================================================================
# .env.example  ->  copy to `~/.axon/.env` and fill in. NEVER commit `.env`.
# -----------------------------------------------------------------------------
# This file holds SECRETS ONLY. Everything else lives in ~/.axon/config.yaml.
# `.env` is read from the current directory by default; if you keep it beside the
# config (~/.axon/.env, recommended), pass `--env ~/.axon/.env`. Values here are
# referenced from the YAML as `env:NAME`. AXON resolves them at runtime and never
# writes them to logs, events, exports or prompts.
#
# AXON reaches Claude through Claude Code (`claude -p` + interactive), so the
# credential it needs is a Claude Code OAuth token, NOT an Anthropic API key.
#
# Generate the token once per installation:
#     claude setup-token        # prints a ~1-year CLAUDE_CODE_OAUTH_TOKEN
# Copy the printed value here. Only the profile you actually run needs a token.
#
# Interactive Claude Code in the vault can instead just use `claude login`;
# the token below is what lets the daemon run SCHEDULED (headless) automations.
# =============================================================================

# --- Personal installation (Claude Max, auth_mode: subscription) -------------
CLAUDE_CODE_OAUTH_TOKEN_PERSONAL=sk-ant-oat01-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Work installation (Claude Enterprise, auth_mode: enterprise) ------------
# Only if your org permits `claude setup-token`. If it disables long-lived
# tokens, leave this unset and run automations under an authenticated session.
CLAUDE_CODE_OAUTH_TOKEN_WORK=sk-ant-oat01-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- DO NOT SET ANTHROPIC_API_KEY --------------------------------------------
# Claude Code prioritises ANTHROPIC_API_KEY over your subscription and bills the
# API account. Keep it unset on subscription/enterprise installs. `axon doctor`
# warns if it finds one. (Only set it for an optional `auth_mode: api_key` install.)
# ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Optional: Ollama (local embeddings) -------------------------------------
# Only set if Ollama is not at the default http://localhost:11434
# OLLAMA_HOST=http://localhost:11434

# --- Optional: override AXON home / active profile ---------------------------
# AXON_HOME=~/.axon
# AXON_PROFILE=personal
